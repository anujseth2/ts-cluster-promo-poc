# ── SOURCE cluster ──────────────────────────────────────────────────────────
# The cluster you promote FROM (e.g. dev/staging cluster).
TS_SOURCE_HOST=https://source-cluster.thoughtspot.cloud
# Auth: use EITHER a bearer token, OR username+password. Token wins if both set.
TS_SOURCE_TOKEN=
TS_SOURCE_USERNAME=
TS_SOURCE_PASSWORD=
# Optional org on the source cluster (leave blank for the default/primary org).
TS_SOURCE_ORG=

# ── TARGET cluster ──────────────────────────────────────────────────────────
# The cluster you promote TO (e.g. prod cluster). A DIFFERENT host + creds.
TS_TARGET_HOST=https://target-cluster.thoughtspot.cloud
TS_TARGET_TOKEN=
TS_TARGET_USERNAME=
TS_TARGET_PASSWORD=
TS_TARGET_ORG=

# ── GitHub (the bridge / source of truth) ───────────────────────────────────
GITHUB_TOKEN=your_github_pat
GITHUB_REPO=anujseth2/ts-cluster-promo
